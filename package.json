{
  "name": "easy-email",
  "private": true,
  "version": "0.2.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && tsc --noEmit -p tsconfig.node.json && vite build",
    "test:unit": "node --test --import tsx src/lib/*.test.ts src/lib/ai-pipeline/**/*.test.ts src/layout-variant-ai-contract/*.test.ts server/*.test.ts src/meta-contract/*.test.ts src/payload-contract/*.test.ts src/block-contract/*.test.ts src/canvas-dimension-contract/*.test.ts src/editor-canvas-contract/*.test.ts src/render-defaults-contract/*.test.ts src/repeat-binding-contract/*.test.ts src/schema-registry/*.test.ts src/repeat-runtime/*.test.ts",
    "validate:schema-registry": "node --test --import tsx src/schema-registry/registry.test.ts",
    "restore:check": "npm run test:unit && npm run template-yaml:golden",
    "preview": "vite preview",
    "server": "tsx watch server/index.ts",
    "dev:all": "concurrently -k \"npm run server\" \"npm run dev\"",
    "build:email:layout-test": "tsx scripts/build-email-layout-test.mjs",
    "build:email:image-test": "tsx scripts/build-email-image-test.mjs",
    "build:email:grid-test": "tsx scripts/build-email-grid-test.mjs",
    "build:email:hug-fill-gap-test": "tsx scripts/build-email-hug-fill-gap-test.mjs",
    "generate:image-test-position-assets": "python3 scripts/generate-image-test-position-assets.py",
    "sync:claude": "node scripts/sync-cursor-to-claude.mjs",
    "sync:claude:check": "node scripts/sync-cursor-to-claude.mjs --check",
    "template-yaml:expand": "tsx scripts/email-template-yaml-to-template.mjs",
    "template-yaml:golden": "tsx scripts/email-template-yaml-to-template.mjs --golden",
    "template-yaml:golden:write": "tsx scripts/email-template-yaml-to-template.mjs --golden --write",
    "migrate:publish-status": "node scripts/migrate-publish-status.mjs",
    "migrate:publish-status:write": "node scripts/migrate-publish-status.mjs --write",
    "validate:all": "tsx scripts/run-validate-all.mjs",
    "validate:email": "tsx scripts/run-validate-all.mjs --skip-unit --skip-yaml --skip-public-presets",
    "manual-restore:doubao": "tsx scripts/run-manual-restore-doubao.ts",
    "sync:masters": "tsx scripts/sync-masters-catalog.ts",
    "sync:icon-cdn-index": "node scripts/sync-icon-cdn-index.mjs"
  },
  "dependencies": {
    "@hono/node-server": "^1.13.1",
    "@shoplazza/sds": "^1.8.15",
    "@shoplazza/sds-icons": "^0.1.317",
    "he": "^1.2.0",
    "hono": "^4.6.11",
    "nodemailer": "^8.0.8",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zod": "^4.4.3",
    "zod-to-json-schema": "^3.25.2"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@types/nodemailer": "^8.0.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.3",
    "concurrently": "^9.1.0",
    "node-html-parser": "^7.1.0",
    "tsx": "^4.19.2",
    "typescript": "~5.6.3",
    "vite": "^5.4.10",
    "yaml": "^2.8.4"
  }
}
