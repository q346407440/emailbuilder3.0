{
  "schemaVersion": "4.0.0",
  "emailId": "yaml_golden_minimal",
  "templateId": "yaml_golden_minimal",
  "templateVersion": 1,
  "locale": "zh-CN",
  "root": {
    "id": "bgm-root",
    "type": "emailRoot",
    "blockMeta": {
      "blockType": "layout.container",
      "name": "画布根节点"
    },
    "props": {
      "border": {
        "style": "solid",
        "color": "rgba(0,0,0,0)",
        "top": "0",
        "right": "0",
        "bottom": "0",
        "left": "0"
      },
      "backgroundColor": "#ffffff",
      "width": "600px",
      "padding": {
        "top": "0",
        "right": "0",
        "bottom": "0",
        "left": "0"
      },
      "gapMode": "fixed",
      "gap": "0"
    },
    "wrapperStyle": {
      "widthMode": "fill",
      "heightMode": "hug"
    },
    "children": [
      {
        "id": "bgm-page",
        "type": "layout",
        "blockMeta": {
          "blockType": "layout.container",
          "name": "主内容区"
        },
        "props": {
          "gap": "16px",
          "direction": "vertical"
        },
        "wrapperStyle": {
          "border": {
            "style": "solid",
            "color": "rgba(0,0,0,0)",
            "top": "0",
            "right": "0",
            "bottom": "0",
            "left": "0"
          },
          "widthMode": "fill",
          "heightMode": "hug",
          "borderRadius": {
            "topLeft": "0",
            "topRight": "0",
            "bottomRight": "0",
            "bottomLeft": "0"
          },
          "backgroundColor": "#ffffff",
          "padding": {
            "top": "24px",
            "right": "24px",
            "bottom": "24px",
            "left": "24px"
          },
          "contentAlign": {
            "horizontal": "left",
            "vertical": "top"
          }
        },
        "children": [
          {
            "id": "bgm-h1",
            "type": "text",
            "blockMeta": {
              "blockType": "content.text",
              "name": "标题"
            },
            "props": {
              "fontSize": "22px",
              "color": "#111111",
              "bold": true,
              "italic": false,
              "decoration": "none",
              "textBody": {
                "paragraphs": [
                  {
                    "runs": [
                      {
                        "text": "YAML Golden"
                      }
                    ]
                  }
                ]
              }
            },
            "wrapperStyle": {
              "contentAlign": {
                "horizontal": "center",
                "vertical": "top"
              },
              "widthMode": "fill",
              "heightMode": "hug"
            }
          },
          {
            "id": "bgm-body",
            "type": "text",
            "blockMeta": {
              "blockType": "content.text",
              "name": "正文"
            },
            "props": {
              "fontSize": "14px",
              "color": "#444444",
              "bold": false,
              "italic": false,
              "decoration": "none",
              "textBody": {
                "paragraphs": [
                  {
                    "runs": [
                      {
                        "text": "由 YAML 展开器生成。"
                      }
                    ]
                  }
                ]
              }
            },
            "wrapperStyle": {
              "contentAlign": {
                "horizontal": "center",
                "vertical": "top"
              },
              "widthMode": "fill",
              "heightMode": "hug"
            }
          },
          {
            "id": "bgm-btn",
            "type": "button",
            "blockMeta": {
              "blockType": "action.button",
              "name": "主按钮"
            },
            "props": {
              "text": "查看",
              "link": "https://example.com",
              "buttonStyle": {
                "border": {
                  "style": "solid",
                  "color": "rgba(0,0,0,0)",
                  "top": "0",
                  "right": "0",
                  "bottom": "0",
                  "left": "0"
                },
                "widthMode": "hug",
                "heightMode": "hug",
                "backgroundColor": "#111111",
                "textColor": "#ffffff",
                "borderRadius": {
                  "topLeft": "0",
                  "topRight": "0",
                  "bottomRight": "0",
                  "bottomLeft": "0"
                },
                "bold": true,
                "italic": false
              }
            },
            "wrapperStyle": {
              "contentAlign": {
                "horizontal": "center",
                "vertical": "top"
              },
              "widthMode": "fill",
              "heightMode": "hug"
            }
