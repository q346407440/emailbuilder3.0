{
  "schemaVersion": "4.0.0",
  "emailId": "ai",
  "templateId": "ai",
  "templateVersion": 1,
  "locale": "zh-CN",
  "root": {
    "id": "ai-root",
    "type": "emailRoot",
    "blockMeta": {
      "blockType": "layout.container",
      "name": "画布根"
    },
    "props": {
      "backgroundColor": "#ffffff",
      "width": "600px",
      "padding": {
        "top": "0",
        "right": "0",
        "bottom": "0",
        "left": "0"
      },
      "border": {
        "style": "solid",
        "color": "rgba(0,0,0,0)",
        "top": "0",
        "right": "0",
        "bottom": "0",
        "left": "0"
      },
      "gapMode": "fixed",
      "gap": "0"
    },
    "wrapperStyle": {
      "widthMode": "fill",
      "heightMode": "hug"
    },
    "children": [
      {
        "id": "ai-row",
        "type": "layout",
        "blockMeta": {
          "blockType": "layout.container",
          "name": "内容区"
        },
        "props": {
          "direction": "vertical",
          "gapMode": "fixed",
          "gap": "8px"
        },
        "wrapperStyle": {
          "contentAlign": {
            "horizontal": "left",
            "vertical": "top"
          },
          "widthMode": "fill",
          "heightMode": "hug",
          "border": {
            "style": "solid",
            "color": "rgba(0,0,0,0)",
            "top": "0",
            "right": "0",
            "bottom": "0",
            "left": "0"
          },
          "borderRadius": {
            "topLeft": "0",
            "topRight": "0",
            "bottomRight": "0",
            "bottomLeft": "0"
          },
          "backgroundColor": "#ffffff",
          "padding": {
            "top": "16px",
            "right": "16px",
            "bottom": "16px",
            "left": "16px"
          }
        },
        "children": [
          {
            "id": "ai-text",
            "type": "text",
            "blockMeta": {
              "blockType": "content.text",
              "name": "正文"
            },
            "props": {
              "textBody": {
                "paragraphs": [
                  {
                    "runs": [
                      {
                        "text": "在此开始编辑邮件内容"
                      }
                    ]
                  }
                ]
              },
              "fontSize": "14px",
              "color": "#111111",
              "bold": false,
              "italic": false,
              "decoration": "none"
            },
            "wrapperStyle": {
              "contentAlign": {
                "horizontal": "left",
                "vertical": "top"
              },
              "widthMode": "hug",
              "heightMode": "hug",
              "border": {
                "style": "solid",
                "color": "rgba(0,0,0,0)",
                "top": "0",
                "right": "0",
                "bottom": "0",
                "left": "0"
              },
              "borderRadius": {
                "topLeft": "0",
                "topRight": "0",
                "bottomRight": "0",
                "bottomLeft": "0"
              }
            }
          }
        ]
      }
    ]
  }
}
