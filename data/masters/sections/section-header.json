{
  "masterId": "section-header",
  "name": "模块 · 顶栏文案",
  "version": "1.0.0",
  "description": "顶栏 Logo 行、主标题与副标题。",
  "rootBlockId": "oca-mod-header",
  "catalogRootBlockId": "__catalog_root__",
  "blocks": {
    "oca-mod-header": {
      "id": "oca-mod-header",
      "type": "layout",
      "parentId": "__catalog_root__",
      "children": [
        "oca-header-logo-row",
        "oca-header-h1",
        "oca-header-sub"
      ],
      "wrapperStyle": {
        "placement": {
          "horizontal": "start",
          "vertical": "start"
        },
        "widthMode": "fill",
        "heightMode": "hug",
        "border": {
          "mode": "unified",
          "width": "0",
          "style": "solid",
          "color": "rgba(0,0,0,0)"
        },
        "borderRadius": {
          "mode": "unified",
          "radius": "0"
        },
        "backgroundColor": {
          "$themeRef": "colors.surface"
        },
        "padding": {
          "mode": "separate",
          "top": {
            "$themeRef": "tokens.spacing.section"
          },
          "right": {
            "$themeRef": "tokens.spacing.pageInline"
          },
          "bottom": {
            "$themeRef": "tokens.spacing.section"
          },
          "left": {
            "$themeRef": "tokens.spacing.pageInline"
          }
        },
        "contentAlign": {
          "vertical": "top",
          "horizontal": "left"
        }
      },
      "props": {
        "direction": "vertical",
        "gapMode": "fixed",
        "gap": {
          "$themeRef": "tokens.spacing.gap"
        }
      },
      "bindings": {
        "wrapperStyle.backgroundColor": {
          "slotId": "colors.surface",
          "mode": "theme",
          "tokenPath": "colors.surface",
          "fieldKind": "style"
        },
        "wrapperStyle.padding.top": {
          "slotId": "tokens.spacing.section",
          "mode": "theme",
          "tokenPath": "tokens.spacing.section",
          "fieldKind": "style"
        },
        "wrapperStyle.padding.bottom": {
          "slotId": "tokens.spacing.section",
          "mode": "theme",
          "tokenPath": "tokens.spacing.section",
          "fieldKind": "style"
        },
        "wrapperStyle.padding.left": {
          "slotId": "tokens.spacing.pageInline",
          "mode": "theme",
          "tokenPath": "tokens.spacing.pageInline",
          "fieldKind": "style"
        },
        "wrapperStyle.padding.right": {
          "slotId": "tokens.spacing.pageInline",
          "mode": "theme",
          "tokenPath": "tokens.spacing.pageInline",
          "fieldKind": "style"
        },
        "props.gap": {
          "slotId": "tokens.spacing.gap",
          "mode": "theme",
          "tokenPath": "tokens.spacing.gap",
          "fieldKind": "style"
        }
      }
    },
    "oca-header-logo-row": {
      "id": "oca-header-logo-row",
      "type": "layout",
      "parentId": "oca-mod-header",
      "children": [
        "oca-header-logo-text"
      ],
      "wrapperStyle": {
        "placement": {
          "horizontal": "center",
          "vertical": "start"
        },
        "widthMode": "fill",
        "heightMode": "hug",
        "border": {
          "mode": "unified",
          "width": "0",
          "style": "solid",
          "color": "rgba(0,0,0,0)"
        },
        "borderRadius": {
          "mode": "corners",
          "topLeft": {
            "$themeRef": "tokens.radius.panel"
          },
          "topRight": {
            "$themeRef": "tokens.radius.panel"
          },
          "bottomRight": {
            "$themeRef": "tokens.radius.panel"
          },
          "bottomLeft": {
            "$themeRef": "tokens.radius.panel"
          }
        },
        "backgroundColor": {
          "$themeRef": "colors.surface"
        },
        "contentAlign": {
          "horizontal": "left",
          "vertical": "top"
        }
      },
      "props": {
        "direction": "horizontal",
        "gapMode": "fixed",
        "gap": "0"
      },
      "bindings": {
        "wrapperStyle.backgroundColor": {
          "slotId": "colors.surface",
          "mode": "theme",
          "tokenPath": "colors.surface",
          "fieldKind": "style"
        },
        "wrapperStyle.borderRadius.topLeft": {
          "slotId": "tokens.radius.panel",
          "mode": "theme",
          "tokenPath": "tokens.radius.panel",
          "fieldKind": "style"
        },
        "wrapperStyle.borderRadius.topRight": {
          "slotId": "tokens.radius.panel",
          "mode": "theme",
          "tokenPath": "tokens.radius.panel",
          "fieldKind": "style"
        },
        "wrapperStyle.borderRadius.bottomRight": {
          "slotId": "tokens.radius.panel",
          "mode": "theme",
          "tokenPath": "tokens.radius.panel",
          "fieldKind": "style"
        },
        "wrapperStyle.borderRadius.bottomLeft": {
          "slotId": "tokens.radius.panel",
          "mode": "theme",
          "tokenPath": "tokens.radius.panel",
          "fieldKind": "style"
        }
      }
    },
    "oca-header-logo-text": {
      "id": "oca-header-logo-text",
      "type": "text",
      "parentId": "oca-header-logo-row",
      "children": [],
      "wrapperStyle": {
        "placement": {
          "horizontal": "center",
          "vertical": "center"
        },
        "contentAlign": {
          "horizontal": "center",
          "vertical": "top"
        },
        "widthMode": "hug",
        "heightMode": "hug",
        "border": {
          "mode": "unified",
          "width": "0",
          "style": "solid",
          "color": "rgba(0,0,0,0)"
        },
        "borderRadius": {
          "mode": "unified",
          "radius": "0"
        }
      },
      "props": {
        "textBody": {
          "version": 1,
          "paragraphs": [
            {
              "runs": [
                {
                  "text": "on"
                }
              ]
            }
          ]
        },
        "fontSize": {
          "$themeRef": "tokens.typography.body"
        },
        "color": {
          "$themeRef": "colors.primary"
        },
        "bold": true,
        "italic": false,
        "decoration": "none",
        "fontFamily": {
          "$themeRef": "fonts.heading"
        }
      },
      "bindings": {
        "props.fontFamily": {
          "slotId": "fonts.heading",
          "mode": "theme",
          "tokenPath": "fonts.heading",
          "fieldKind": "style"
        },
        "props.fontSize": {
          "slotId": "tokens.typography.body",
          "mode": "theme",
          "tokenPath": "tokens.typography.body",
          "fieldKind": "style"
        },
        "props.color": {
          "slotId": "colors.primary",
          "mode": "theme",
          "tokenPath": "colors.primary",
          "fieldKind": "style"
        }
      }
    },
    "oca-header-h1": {
      "id": "oca-header-h1",
      "type": "text",
      "parentId": "oca-mod-header",
      "children": [],
      "wrapperStyle": {
        "placement": {
          "horizontal": "start",
          "vertical": "start"
        },
        "contentAlign": {
          "horizontal": "center",
          "vertical": "top"
        },
        "widthMode": "fill",
        "heightMode": "hug",
        "border": {
          "mode": "unified",
          "width": "0",
          "style": "solid",
          "color": "rgba(0,0,0,0)"
        },
        "borderRadius": {
          "mode": "unified",
          "radius": "0"
        }
      },
      "props": {
        "textBody": {
          "version": 1,
          "paragraphs": [
            {
              "runs": [
                {
                  "text": "Your viewed items are selling fast"
                }
              ]
            }
          ]
        },
        "fontSize": {
          "$themeRef": "tokens.typography.display"
        },
        "color": {
          "$themeRef": "colors.primary"
        },
        "bold": false,
        "italic": false,
        "decoration": "none",
        "fontFamily": {
          "$themeRef": "fonts.heading"
        }
      },
      "bindings": {
        "props.textBody.paragraphs.0.runs.0.text": {
          "slotId": "viewedItemsHeadline",
          "mode": "variable",
          "valueType": "string",
          "defaultValue": "Your viewed items are selling fast",
          "allowExternal": true,
          "fieldKind": "content",
          "label": "主标题文案",
          "description": "弃购挽留邮件首屏标题。"
        },
        "props.fontFamily": {
          "slotId": "fonts.heading",
          "mode": "theme",
          "tokenPath": "fonts.heading",
          "fieldKind": "style"
        },
        "props.fontSize": {
          "slotId": "tokens.typography.display",
          "mode": "theme",
          "tokenPath": "tokens.typography.display",
          "fieldKind": "style"
        },
        "props.color": {
          "slotId": "colors.primary",
          "mode": "theme",
          "tokenPath": "colors.primary",
          "fieldKind": "style"
        }
      }
    },
    "oca-header-sub": {
      "id": "oca-header-sub",
      "type": "text",
      "parentId": "oca-mod-header",
      "children": [],
      "wrapperStyle": {
        "placement": {
          "horizontal": "start",
          "vertical": "start"
        },
        "contentAlign": {
          "horizontal": "center",
          "vertical": "top"
        },
        "widthMode": "fill",
        "heightMode": "hug",
        "border": {
          "mode": "unified",
          "width": "0",
          "style": "solid",
          "color": "rgba(0,0,0,0)"
        },
        "borderRadius": {
          "mode": "unified",
          "radius": "0"
        }
      },
      "props": {
        "textBody": {
          "version": 1,
          "paragraphs": [
            {
              "runs": [
                {
                  "text": "Add them to your cart with free shipping."
                }
              ]
            }
          ]
        },
        "fontSize": {
          "$themeRef": "tokens.typography.body"
        },
        "color": {
          "$themeRef": "colors.secondary"
        },
        "bold": false,
        "italic": false,
        "decoration": "none",
        "fontFamily": {
          "$themeRef": "fonts.body"
        }
      },
      "bindings": {
        "props.textBody.paragraphs.0.runs.0.text": {
          "slotId": "viewedItemsSubheadline",
          "mode": "variable",
          "valueType": "string",
          "defaultValue": "Add them to your cart with free shipping.",
          "allowExternal": true,
          "fieldKind": "content",
          "label": "副标题文案",
          "description": "弃购挽留邮件首屏副标题。"
        },
        "props.fontFamily": {
          "slotId": "fonts.body",
          "mode": "theme",
          "tokenPath": "fonts.body",
          "fieldKind": "style"
        },
        "props.fontSize": {
          "slotId": "tokens.typography.body",
          "mode": "theme",
          "tokenPath": "tokens.typography.body",
          "fieldKind": "style"
        },
        "props.color": {
          "slotId": "colors.secondary",
          "mode": "theme",
          "tokenPath": "colors.secondary",
          "fieldKind": "style"
        }
      }
    },
    "__catalog_root__": {
      "id": "__catalog_root__",
      "type": "emailRoot",
      "parentId": null,
      "children": [
        "oca-mod-header"
      ],
      "wrapperStyle": {
        "placement": {
          "horizontal": "center"
        },
        "widthMode": "fill",
        "heightMode": "hug"
      },
      "props": {
        "backgroundColor": "#FFFFFF",
        "width": "600px",
        "padding": {
          "mode": "unified",
          "unified": "0"
        },
        "border": {
          "mode": "unified",
          "width": "0",
          "style": "solid",
          "color": "rgba(0,0,0,0)"
        },
        "gapMode": "fixed",
        "gap": "0"
      },
      "bindings": {}
    }
  },
  "blockMeta": {
    "oca-mod-header": {
      "blockType": "layout.container",
      "name": "模块 · 顶栏文案"
    },
    "oca-header-logo-row": {
      "blockType": "layout.container",
      "name": "顶栏 Logo 行"
    },
    "oca-header-logo-text": {
      "blockType": "content.text",
      "name": "品牌字标"
    },
    "oca-header-h1": {
      "blockType": "content.text",
      "name": "主标题"
    },
    "oca-header-sub": {
      "blockType": "content.text",
      "name": "副标题"
    },
    "__catalog_root__": {
      "blockType": "layout.container",
      "name": "预览根"
    }
  }
}
