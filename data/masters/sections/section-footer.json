{
  "masterId": "section-footer",
  "name": "模块 · 页脚",
  "version": "1.0.0",
  "description": "包邮横幅、Logo、社媒图标、链接与版权信息。",
  "rootBlockId": "oca-mod-footer",
  "catalogRootBlockId": "__catalog_root__",
  "blocks": {
    "oca-mod-footer": {
      "id": "oca-mod-footer",
      "type": "layout",
      "parentId": "__catalog_root__",
      "children": [
        "oca-ft-ship",
        "oca-ft-logo-row",
        "oca-ft-icons",
        "oca-ft-links",
        "oca-ft-copy",
        "oca-ft-legal"
      ],
      "wrapperStyle": {
        "placement": {
          "horizontal": "start",
          "vertical": "start"
        },
        "widthMode": "fill",
        "heightMode": "hug",
        "border": {
          "mode": "unified",
          "width": "0",
          "style": "solid",
          "color": "rgba(0,0,0,0)"
        },
        "borderRadius": {
          "mode": "unified",
          "radius": "0"
        },
        "backgroundColor": {
          "$themeRef": "colors.surface"
        },
        "padding": {
          "mode": "separate",
          "top": {
            "$themeRef": "tokens.spacing.section"
          },
          "right": {
            "$themeRef": "tokens.spacing.pageInline"
          },
          "bottom": {
            "$themeRef": "tokens.spacing.section"
          },
          "left": {
            "$themeRef": "tokens.spacing.pageInline"
          }
        },
        "contentAlign": {
          "vertical": "top",
          "horizontal": "left"
        }
      },
      "props": {
        "direction": "vertical",
        "gapMode": "fixed",
        "gap": {
          "$themeRef": "tokens.spacing.gap"
        }
      },
      "bindings": {
        "wrapperStyle.backgroundColor": {
          "slotId": "colors.surface",
          "mode": "theme",
          "tokenPath": "colors.surface",
          "fieldKind": "style"
        },
        "wrapperStyle.padding.top": {
          "slotId": "tokens.spacing.section",
          "mode": "theme",
          "tokenPath": "tokens.spacing.section",
          "fieldKind": "style"
        },
        "wrapperStyle.padding.bottom": {
          "slotId": "tokens.spacing.section",
          "mode": "theme",
          "tokenPath": "tokens.spacing.section",
          "fieldKind": "style"
        },
        "wrapperStyle.padding.left": {
          "slotId": "tokens.spacing.pageInline",
          "mode": "theme",
          "tokenPath": "tokens.spacing.pageInline",
          "fieldKind": "style"
        },
        "wrapperStyle.padding.right": {
          "slotId": "tokens.spacing.pageInline",
          "mode": "theme",
          "tokenPath": "tokens.spacing.pageInline",
          "fieldKind": "style"
        },
        "props.gap": {
          "slotId": "tokens.spacing.gap",
          "mode": "theme",
          "tokenPath": "tokens.spacing.gap",
          "fieldKind": "style"
        }
      }
