        },
        "contentAlign": {
          "horizontal": "left",
          "vertical": "top"
        }
      },
      "props": {},
      "bindings": {
        "wrapperStyle.backgroundImage.src": {
          "slotId": "featuredProduct",
          "mode": "variable",
          "valueType": "collection",
          "defaultValue": [
            {
              "imageSrc": "https://images.pexels.com/photos/2529148/pexels-photo-2529148.jpeg?auto=compress&cs=tinysrgb&w=800",
              "imageAlt": "Cloud",
              "name": "Cloud",
              "href": "https://example.com/"
            }
          ],
          "allowExternal": true,
          "fieldKind": "content",
          "slotPath": "0.imageSrc",
          "label": "主推商品列表",
          "description": "用于驱动主推灰底容器的商品图、名称与跳转链接（固定 1 项）。",
          "itemFields": [
            {
              "key": "imageSrc",
              "label": "图片地址",
              "valueType": "image",
              "required": true
            },
            {
              "key": "imageAlt",
              "label": "图片 alt",
              "valueType": "string",
              "placeholder": "可为空"
            },
            {
              "key": "name",
              "label": "商品名称",
              "valueType": "string",
              "required": true
            },
            {
              "key": "href",
              "label": "商品链接",
              "valueType": "url",
              "required": true
            }
          ],
          "minItems": 1,
          "maxItems": 1
        },
        "wrapperStyle.backgroundImage.alt": {
          "slotId": "featuredProduct",
          "mode": "variable",
          "valueType": "collection",
          "allowExternal": true,
          "fieldKind": "content",
          "slotPath": "0.imageAlt"
