        "placement": {
          "horizontal": "start",
          "vertical": "start"
        },
        "widthMode": "fill",
        "heightMode": "fixed",
        "height": "280px",
        "border": {
          "mode": "unified",
          "width": "0",
          "style": "solid",
          "color": "rgba(0,0,0,0)"
        },
        "borderRadius": {
          "mode": "unified",
          "radius": "0"
        },
        "backgroundImage": {
          "src": "https://images.pexels.com/photos/2529148/pexels-photo-2529148.jpeg?auto=compress&cs=tinysrgb&w=800",
          "alt": "Running shoe product",
          "link": "",
          "fit": "cover",
          "position": "center",
          "borderRadius": {
            "mode": "unified",
            "radius": "0"
          },
