{
  "masterId": "section-hero",
  "name": "模块 · 主推商品",
  "version": "1.0.0",
  "description": "灰底主推区：主图、款名与 CTA 按钮。",
  "rootBlockId": "oca-mod-hero",
  "catalogRootBlockId": "__catalog_root__",
  "blocks": {
    "oca-mod-hero": {
      "id": "oca-mod-hero",
      "type": "layout",
      "parentId": "__catalog_root__",
      "children": [
        "oca-hero-inner"
      ],
      "wrapperStyle": {
        "widthMode": "fill",
        "heightMode": "hug",
        "border": {
          "mode": "unified",
          "width": "0",
          "style": "solid",
          "color": "rgba(0,0,0,0)"
        },
        "borderRadius": {
          "mode": "unified",
          "radius": "0"
        },
        "backgroundColor": {
          "$themeRef": "colors.surface"
        },
        "padding": {
          "mode": "separate",
          "top": {
            "$themeRef": "tokens.spacing.section"
          },
          "right": {
            "$themeRef": "tokens.spacing.pageInline"
          },
          "bottom": {
            "$themeRef": "tokens.spacing.section"
          },
          "left": {
            "$themeRef": "tokens.spacing.pageInline"
          }
        },
        "contentAlign": {
          "vertical": "top",
          "horizontal": "left"
        }
      },
      "props": {
        "direction": "vertical",
        "gapMode": "fixed",
        "gap": {
          "$themeRef": "tokens.spacing.gap"
        }
      },
      "bindings": {
        "wrapperStyle.backgroundColor": {
          "slotId": "colors.surface",
          "mode": "theme",
          "tokenPath": "colors.surface",
          "fieldKind": "style"
        },
        "wrapperStyle.padding.top": {
          "slotId": "tokens.spacing.section",
          "mode": "theme",
          "tokenPath": "tokens.spacing.section",
          "fieldKind": "style"
        },
        "wrapperStyle.padding.bottom": {
          "slotId": "tokens.spacing.section",
          "mode": "theme",
          "tokenPath": "tokens.spacing.section",
          "fieldKind": "style"
        },
        "wrapperStyle.padding.left": {
          "slotId": "tokens.spacing.pageInline",
          "mode": "theme",
          "tokenPath": "tokens.spacing.pageInline",
          "fieldKind": "style"
        },
        "wrapperStyle.padding.right": {
          "slotId": "tokens.spacing.pageInline",
          "mode": "theme",
          "tokenPath": "tokens.spacing.pageInline",
          "fieldKind": "style"
        },
        "props.gap": {
          "slotId": "tokens.spacing.gap",
          "mode": "theme",
          "tokenPath": "tokens.spacing.gap",
          "fieldKind": "style"
        }
      }
    },
    "oca-hero-inner": {
      "id": "oca-hero-inner",
      "type": "layout",
      "parentId": "oca-mod-hero",
      "children": [
        "oca-hero-img",
        "oca-hero-name",
        "oca-hero-btn"
      ],
      "wrapperStyle": {
        "widthMode": "fill",
        "heightMode": "hug",
        "border": {
          "mode": "unified",
          "width": "0",
          "style": "solid",
          "color": "rgba(0,0,0,0)"
        },
        "borderRadius": {
          "mode": "corners",
          "topLeft": {
            "$themeRef": "tokens.radius.panel"
          },
          "topRight": {
            "$themeRef": "tokens.radius.panel"
          },
          "bottomRight": {
            "$themeRef": "tokens.radius.panel"
          },
          "bottomLeft": {
            "$themeRef": "tokens.radius.panel"
          }
        },
        "backgroundColor": {
          "$themeRef": "colors.surface"
        },
        "padding": {
          "mode": "separate",
          "top": {
            "$themeRef": "tokens.spacing.section"
          },
          "right": {
            "$themeRef": "tokens.spacing.pageInline"
          },
          "bottom": {
            "$themeRef": "tokens.spacing.section"
          },
          "left": {
            "$themeRef": "tokens.spacing.pageInline"
          }
        },
        "contentAlign": {
          "vertical": "top",
          "horizontal": "left"
        }
      },
      "props": {
        "direction": "vertical",
        "gapMode": "fixed",
        "gap": {
          "$themeRef": "tokens.spacing.gap"
        }
      },
      "bindings": {
        "wrapperStyle.backgroundColor": {
          "slotId": "colors.surface",
          "mode": "theme",
          "tokenPath": "colors.surface",
          "fieldKind": "style"
        },
        "wrapperStyle.padding.top": {
          "slotId": "tokens.spacing.section",
          "mode": "theme",
          "tokenPath": "tokens.spacing.section",
          "fieldKind": "style"
        },
        "wrapperStyle.padding.bottom": {
          "slotId": "tokens.spacing.section",
          "mode": "theme",
          "tokenPath": "tokens.spacing.section",
          "fieldKind": "style"
        },
        "wrapperStyle.padding.left": {
          "slotId": "tokens.spacing.pageInline",
          "mode": "theme",
          "tokenPath": "tokens.spacing.pageInline",
          "fieldKind": "style"
        },
        "wrapperStyle.padding.right": {
          "slotId": "tokens.spacing.pageInline",
          "mode": "theme",
          "tokenPath": "tokens.spacing.pageInline",
          "fieldKind": "style"
        },
        "props.gap": {
          "slotId": "tokens.spacing.gap",
          "mode": "theme",
          "tokenPath": "tokens.spacing.gap",
          "fieldKind": "style"
        },
        "wrapperStyle.borderRadius.topLeft": {
          "slotId": "tokens.radius.panel",
          "mode": "theme",
          "tokenPath": "tokens.radius.panel",
          "fieldKind": "style"
        },
        "wrapperStyle.borderRadius.topRight": {
          "slotId": "tokens.radius.panel",
          "mode": "theme",
          "tokenPath": "tokens.radius.panel",
          "fieldKind": "style"
        },
        "wrapperStyle.borderRadius.bottomRight": {
          "slotId": "tokens.radius.panel",
          "mode": "theme",
          "tokenPath": "tokens.radius.panel",
          "fieldKind": "style"
        },
        "wrapperStyle.borderRadius.bottomLeft": {
          "slotId": "tokens.radius.panel",
          "mode": "theme",
          "tokenPath": "tokens.radius.panel",
          "fieldKind": "style"
        }
      }
    },
    "oca-hero-img": {
      "id": "oca-hero-img",
      "type": "image",
      "parentId": "oca-hero-inner",
      "children": [],
      "wrapperStyle": {
        "widthMode": "fill",
        "heightMode": "fixed",
        "height": "280px",
        "border": {
          "mode": "unified",
          "width": "0",
          "style": "solid",
          "color": "rgba(0,0,0,0)"
        },
        "borderRadius": {
          "mode": "unified",
          "radius": "0"
        },
        "backgroundImage": {
          "src": "https://images.pexels.com/photos/2529148/pexels-photo-2529148.jpeg?auto=compress&cs=tinysrgb&w=800",
          "alt": "Running shoe product",
          "link": "",
          "fit": "cover",
          "position": "center",
          "borderRadius": {
            "mode": "unified",
            "radius": "0"
          },
          "border": {
            "mode": "unified",
            "width": "0",
            "style": "solid",
            "color": "rgba(0,0,0,0)"
          }
        },
        "contentAlign": {
          "horizontal": "left",
          "vertical": "top"
        }
      },
      "props": {},
      "bindings": {
        "wrapperStyle.backgroundImage.src": {
          "slotId": "featuredProduct",
          "mode": "variable",
          "valueType": "collection",
          "defaultValue": [
            {
              "imageSrc": "https://images.pexels.com/photos/2529148/pexels-photo-2529148.jpeg?auto=compress&cs=tinysrgb&w=800",
              "imageAlt": "Cloud",
              "name": "Cloud",
              "href": "https://example.com/"
            }
          ],
          "allowExternal": true,
          "fieldKind": "content",
          "slotPath": "0.imageSrc",
          "label": "主推商品列表",
          "description": "用于驱动主推灰底容器的商品图、名称与跳转链接（固定 1 项）。",
          "itemFields": [
            {
              "key": "imageSrc",
              "label": "图片地址",
              "valueType": "image",
              "required": true
            },
            {
              "key": "imageAlt",
              "label": "图片 alt",
              "valueType": "string",
              "placeholder": "可为空"
            },
            {
              "key": "name",
              "label": "商品名称",
              "valueType": "string",
              "required": true
            },
            {
              "key": "href",
              "label": "商品链接",
              "valueType": "url",
              "required": true
            }
          ],
          "minItems": 1,
          "maxItems": 1
        },
        "wrapperStyle.backgroundImage.alt": {
          "slotId": "featuredProduct",
          "mode": "variable",
          "valueType": "collection",
          "allowExternal": true,
          "fieldKind": "content",
          "slotPath": "0.imageAlt"
        }
      }
    },
    "oca-hero-name": {
      "id": "oca-hero-name",
      "type": "text",
      "parentId": "oca-hero-inner",
      "children": [],
      "wrapperStyle": {
        "contentAlign": {
          "horizontal": "center",
          "vertical": "top"
        },
        "widthMode": "fill",
        "heightMode": "hug",
        "border": {
          "mode": "unified",
          "width": "0",
          "style": "solid",
          "color": "rgba(0,0,0,0)"
        },
        "borderRadius": {
          "mode": "unified",
          "radius": "0"
        }
      },
      "props": {
        "textBody": {
          "paragraphs": [
            {
              "runs": [
                {
                  "text": "Cloud"
                }
              ]
            }
          ]
        },
        "fontSize": {
          "$themeRef": "tokens.typography.body"
        },
        "color": {
          "$themeRef": "colors.primary"
        },
        "bold": true,
        "italic": false,
        "decoration": "none"
      },
      "bindings": {
        "props.textBody.paragraphs.0.runs.0.text": {
          "slotId": "featuredProduct",
          "mode": "variable",
          "valueType": "collection",
          "allowExternal": true,
          "fieldKind": "content",
          "slotPath": "0.name"
        },
        "props.fontSize": {
          "slotId": "tokens.typography.body",
          "mode": "theme",
          "tokenPath": "tokens.typography.body",
          "fieldKind": "style"
        },
        "props.color": {
          "slotId": "colors.primary",
          "mode": "theme",
          "tokenPath": "colors.primary",
          "fieldKind": "style"
        }
      }
    },
    "oca-hero-btn": {
      "id": "oca-hero-btn",
      "type": "button",
      "parentId": "oca-hero-inner",
      "children": [],
      "wrapperStyle": {
        "widthMode": "fill",
        "heightMode": "hug",
        "border": {
          "mode": "unified",
          "width": "0",
          "style": "solid",
          "color": "rgba(0,0,0,0)"
        },
        "borderRadius": {
          "mode": "unified",
          "radius": "0"
        },
        "contentAlign": {
          "horizontal": "center",
          "vertical": "top"
        }
      },
      "props": {
        "text": "Shop now",
        "link": "https://example.com/",
        "buttonStyle": {
          "backgroundColor": {
            "$themeRef": "colors.surface"
          },
          "textColor": {
            "$themeRef": "colors.primary"
          },
          "fontSize": {
            "$themeRef": "tokens.typography.body"
          },
          "border": {
            "mode": "unified",
            "width": "1px",
            "style": "solid",
            "color": {
              "$themeRef": "colors.primary"
            }
          },
          "borderRadius": {
            "mode": "corners",
            "topLeft": {
              "$themeRef": "tokens.radius.cta"
            },
            "topRight": {
              "$themeRef": "tokens.radius.cta"
            },
            "bottomRight": {
              "$themeRef": "tokens.radius.cta"
            },
            "bottomLeft": {
              "$themeRef": "tokens.radius.cta"
            }
          },
          "bold": false,
          "italic": false,
          "widthMode": "hug"
        }
      },
      "bindings": {
        "props.text": {
          "slotId": "featuredProductCtaText",
          "mode": "variable",
          "valueType": "string",
          "defaultValue": "Shop now",
          "allowExternal": true,
          "fieldKind": "content",
          "label": "主推按钮文案",
          "description": "主推商品卡片按钮文案。"
        },
        "props.link": {
          "slotId": "featuredProduct",
          "mode": "variable",
          "valueType": "collection",
          "allowExternal": true,
          "fieldKind": "content",
          "slotPath": "0.href"
        },
        "props.buttonStyle.borderRadius.topLeft": {
          "slotId": "tokens.radius.cta",
          "mode": "theme",
          "tokenPath": "tokens.radius.cta",
          "fieldKind": "style"
        },
        "props.buttonStyle.borderRadius.topRight": {
          "slotId": "tokens.radius.cta",
          "mode": "theme",
          "tokenPath": "tokens.radius.cta",
          "fieldKind": "style"
        },
        "props.buttonStyle.borderRadius.bottomRight": {
          "slotId": "tokens.radius.cta",
          "mode": "theme",
          "tokenPath": "tokens.radius.cta",
          "fieldKind": "style"
        },
        "props.buttonStyle.borderRadius.bottomLeft": {
          "slotId": "tokens.radius.cta",
          "mode": "theme",
          "tokenPath": "tokens.radius.cta",
          "fieldKind": "style"
        },
        "props.buttonStyle.fontSize": {
          "slotId": "tokens.typography.body",
          "mode": "theme",
          "tokenPath": "tokens.typography.body",
          "fieldKind": "style"
        },
        "props.buttonStyle.backgroundColor": {
          "slotId": "colors.surface",
          "mode": "theme",
          "tokenPath": "colors.surface",
          "fieldKind": "style"
        },
        "props.buttonStyle.textColor": {
          "slotId": "colors.primary",
          "mode": "theme",
          "tokenPath": "colors.primary",
          "fieldKind": "style"
        },
        "props.buttonStyle.border.color": {
          "slotId": "colors.primary",
          "mode": "theme",
          "tokenPath": "colors.primary",
          "fieldKind": "style"
        }
      }
    },
    "__catalog_root__": {
      "id": "__catalog_root__",
      "type": "emailRoot",
      "parentId": null,
      "children": [
        "oca-mod-hero"
      ],
      "wrapperStyle": {
        "widthMode": "fill",
        "heightMode": "hug"
      },
      "props": {
        "backgroundColor": "#FFFFFF",
        "width": "600px",
        "padding": {
          "mode": "unified",
          "unified": "0"
        },
        "border": {
          "mode": "unified",
          "width": "0",
          "style": "solid",
          "color": "rgba(0,0,0,0)"
        },
        "gapMode": "fixed",
        "gap": "0"
      },
      "bindings": {}
    }
  },
  "blockMeta": {
    "oca-mod-hero": {
      "blockType": "layout.container",
      "name": "模块 · 主推商品"
    },
    "oca-hero-inner": {
      "blockType": "layout.container",
      "name": "主推灰底容器"
    },
    "oca-hero-img": {
      "blockType": "content.image",
      "name": "主推鞋图"
    },
    "oca-hero-name": {
      "blockType": "content.text",
      "name": "主推款名"
    },
    "oca-hero-btn": {
      "blockType": "action.button",
      "name": "主推按钮"
    },
    "__catalog_root__": {
      "blockType": "layout.container",
      "name": "预览根"
    }
  }
}
