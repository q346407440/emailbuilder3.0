{
  "schemaVersion": "4.0.0",
  "masterId": "content.icon",
  "name": "图标",
  "version": "1.0.0",
  "description": "小尺寸图标，src 与跳转链接为内容字段。",
  "runtimeType": "icon",
  "blockType": "content.icon",
  "sampleBlockId": "__sample_icon__",
  "catalogRootBlockId": "__catalog_root__",
  "root": {
    "id": "__catalog_root__",
    "type": "emailRoot",
    "blockMeta": {
      "blockType": "layout.container",
      "name": "预览根"
    },
    "props": {
      "backgroundColor": "#FFFFFF",
      "width": "600px",
      "padding": {
        "mode": "unified",
        "unified": "0"
      },
      "border": {
        "mode": "unified",
        "width": "0",
        "style": "solid",
        "color": "rgba(0,0,0,0)"
      },
      "gapMode": "fixed",
      "gap": "0"
    },
    "wrapperStyle": {
      "widthMode": "fill",
      "heightMode": "hug"
    },
    "children": [
      {
        "id": "__sample_icon__",
        "type": "icon",
        "blockMeta": {
          "blockType": "content.icon",
          "name": "图标"
        },
        "props": {
          "src": "https://cdn.jsdelivr.net/npm/@tabler/icons@3.21.0/icons/outline/photo.svg",
          "link": "",
          "color": {
            "$themeRef": "colors.primary"
          },
          "size": "20px"
        },
        "wrapperStyle": {
          "contentAlign": {
            "horizontal": "center",
            "vertical": "center"
          },
          "widthMode": "hug",
          "heightMode": "hug",
          "border": {
            "mode": "unified",
            "width": "0",
            "style": "solid",
            "color": "rgba(0,0,0,0)"
          },
          "borderRadius": {
            "mode": "unified",
            "radius": "0"
          }
        },
        "bindings": {
          "props.color": {
            "slotId": "colors.primary",
            "mode": "theme",
            "tokenPath": "colors.primary",
            "fieldKind": "style"
          }
        }
      }
    ]
  }
}
