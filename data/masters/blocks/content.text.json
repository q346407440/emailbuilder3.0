{
  "schemaVersion": "4.0.0",
  "masterId": "content.text",
  "name": "文本",
  "version": "1.0.0",
  "description": "富文本段落，支持字号、颜色与对齐。",
  "runtimeType": "text",
  "blockType": "content.text",
  "sampleBlockId": "__sample_text__",
  "catalogRootBlockId": "__catalog_root__",
  "root": {
    "id": "__catalog_root__",
    "type": "emailRoot",
    "blockMeta": {
      "blockType": "layout.container",
      "name": "预览根"
    },
    "props": {
      "backgroundColor": "#FFFFFF",
      "width": "600px",
      "padding": {
        "mode": "unified",
        "unified": "0"
      },
      "border": {
        "mode": "unified",
        "width": "0",
        "style": "solid",
        "color": "rgba(0,0,0,0)"
      },
      "gapMode": "fixed",
      "gap": "0"
    },
    "wrapperStyle": {
      "widthMode": "fill",
      "heightMode": "hug"
    },
    "children": [
      {
        "id": "__sample_text__",
        "type": "text",
        "blockMeta": {
          "blockType": "content.text",
          "name": "文本"
        },
        "props": {
          "textBody": {
            "paragraphs": [
              {
                "runs": [
                  {
                    "text": "示例正文"
                  }
                ]
              }
            ]
          },
          "fontSize": {
            "$themeRef": "tokens.typography.body"
          },
          "color": {
            "$themeRef": "colors.primary"
          },
          "bold": false,
          "italic": false,
          "decoration": "none"
        },
        "wrapperStyle": {
          "contentAlign": {
            "horizontal": "left",
            "vertical": "top"
          },
          "widthMode": "fill",
          "heightMode": "hug",
          "border": {
            "mode": "unified",
            "width": "0",
            "style": "solid",
            "color": "rgba(0,0,0,0)"
          },
          "borderRadius": {
            "mode": "unified",
            "radius": "0"
          }
        },
        "bindings": {
          "props.fontSize": {
            "slotId": "tokens.typography.body",
            "mode": "theme",
            "tokenPath": "tokens.typography.body",
            "fieldKind": "style"
          },
          "props.color": {
            "slotId": "colors.primary",
            "mode": "theme",
            "tokenPath": "colors.primary",
            "fieldKind": "style"
          }
        }
      }
    ]
  }
}
