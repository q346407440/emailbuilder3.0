{
  "schemaVersion": "4.0.0",
  "masterId": "layout.grid",
  "name": "栅格",
  "version": "1.0.0",
  "description": "多列栅格布局，子项顺序与 columns 一致；单元格宽高在 props 配置。",
  "runtimeType": "grid",
  "blockType": "layout.grid",
  "sampleBlockId": "__sample_grid__",
  "catalogRootBlockId": "__catalog_root__",
  "root": {
    "id": "__catalog_root__",
    "type": "emailRoot",
    "blockMeta": {
      "blockType": "layout.container",
      "name": "预览根"
    },
    "props": {
      "backgroundColor": "#FFFFFF",
      "width": "600px",
      "padding": {
        "mode": "unified",
        "unified": "0"
      },
      "border": {
        "mode": "unified",
        "width": "0",
        "style": "solid",
        "color": "rgba(0,0,0,0)"
      },
      "gapMode": "fixed",
      "gap": "0"
    },
    "wrapperStyle": {
      "widthMode": "fill",
      "heightMode": "hug"
    },
    "children": [
      {
        "id": "__sample_grid__",
        "type": "grid",
        "blockMeta": {
          "blockType": "layout.grid",
          "name": "栅格"
        },
        "props": {
          "columns": 2,
          "gap": {
            "$themeRef": "tokens.spacing.gap"
          },
          "cellWidthMode": "auto",
          "cellHeightMode": "content-max"
        },
        "wrapperStyle": {
          "contentAlign": {
            "horizontal": "left",
            "vertical": "top"
          },
          "widthMode": "fill",
          "heightMode": "hug",
          "border": {
            "mode": "unified",
            "width": "0",
            "style": "solid",
            "color": "rgba(0,0,0,0)"
          },
          "borderRadius": {
            "mode": "unified",
            "radius": "0"
          },
          "padding": {
            "mode": "separate",
            "top": {
              "$themeRef": "tokens.spacing.section"
            },
            "right": {
              "$themeRef": "tokens.spacing.pageInline"
            },
            "bottom": {
              "$themeRef": "tokens.spacing.section"
            },
            "left": {
              "$themeRef": "tokens.spacing.pageInline"
            }
          }
        },
        "bindings": {
          "props.gap": {
            "slotId": "tokens.spacing.gap",
            "mode": "theme",
            "tokenPath": "tokens.spacing.gap",
            "fieldKind": "style"
          },
          "wrapperStyle.padding.top": {
            "slotId": "tokens.spacing.section",
            "mode": "theme",
            "tokenPath": "tokens.spacing.section",
            "fieldKind": "style"
          },
          "wrapperStyle.padding.right": {
            "slotId": "tokens.spacing.pageInline",
            "mode": "theme",
            "tokenPath": "tokens.spacing.pageInline",
            "fieldKind": "style"
          },
          "wrapperStyle.padding.bottom": {
            "slotId": "tokens.spacing.section",
            "mode": "theme",
            "tokenPath": "tokens.spacing.section",
            "fieldKind": "style"
          },
          "wrapperStyle.padding.left": {
            "slotId": "tokens.spacing.pageInline",
            "mode": "theme",
            "tokenPath": "tokens.spacing.pageInline",
            "fieldKind": "style"
          }
        },
        "children": [
          {
            "id": "__demo_grid_cell_1__",
            "type": "text",
            "blockMeta": {
              "blockType": "content.text",
              "name": "栅格单元 1"
            },
            "props": {
              "textBody": {
                "paragraphs": [
                  {
                    "runs": [
                      {
                        "text": "栅格单元 1"
                      }
                    ]
