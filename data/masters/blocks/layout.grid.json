{
  "masterId": "layout.grid",
  "name": "栅格",
  "version": "1.0.0",
  "description": "多列栅格布局，子项顺序与 columns 一致；单元格宽高在 props 配置。",
  "runtimeType": "grid",
  "blockType": "layout.grid",
  "sampleBlockId": "__sample_grid__",
  "catalogRootBlockId": "__catalog_root__",
  "blocks": {
    "__catalog_root__": {
      "id": "__catalog_root__",
      "type": "emailRoot",
      "parentId": null,
      "children": [
        "__sample_grid__"
      ],
      "wrapperStyle": {
        "placement": {
          "horizontal": "center"
        },
        "widthMode": "fill",
        "heightMode": "hug"
      },
      "props": {
        "backgroundColor": "#FFFFFF",
        "width": "600px",
        "padding": {
          "mode": "unified",
          "unified": "0"
        },
        "border": {
          "mode": "unified",
          "width": "0",
          "style": "solid",
          "color": "rgba(0,0,0,0)"
        },
        "gapMode": "fixed",
        "gap": "0"
      },
      "bindings": {}
    },
    "__sample_grid__": {
      "id": "__sample_grid__",
      "type": "grid",
      "parentId": "__catalog_root__",
      "children": [
        "__demo_grid_cell_1__",
        "__demo_grid_cell_2__",
        "__demo_grid_cell_3__",
        "__demo_grid_cell_4__"
      ],
      "wrapperStyle": {
        "placement": {
          "horizontal": "center",
          "vertical": "center"
        },
        "contentAlign": {
          "horizontal": "left",
          "vertical": "top"
        },
        "widthMode": "fill",
        "heightMode": "hug",
        "border": {
          "mode": "unified",
          "width": "0",
          "style": "solid",
          "color": "rgba(0,0,0,0)"
        },
        "borderRadius": {
          "mode": "unified",
          "radius": "0"
        },
        "padding": {
          "mode": "separate",
          "top": {
            "$themeRef": "tokens.spacing.section"
          },
          "right": {
            "$themeRef": "tokens.spacing.pageInline"
          },
          "bottom": {
            "$themeRef": "tokens.spacing.section"
          },
          "left": {
            "$themeRef": "tokens.spacing.pageInline"
          }
        }
      },
      "props": {
        "columns": 2,
        "gap": {
          "$themeRef": "tokens.spacing.gap"
        },
        "cellWidthMode": "auto",
        "cellHeightMode": "content-max"
      },
      "bindings": {
        "props.gap": {
          "slotId": "tokens.spacing.gap",
          "mode": "theme",
          "tokenPath": "tokens.spacing.gap",
          "fieldKind": "style"
        },
        "wrapperStyle.padding.top": {
          "slotId": "tokens.spacing.section",
          "mode": "theme",
          "tokenPath": "tokens.spacing.section",
          "fieldKind": "style"
        },
        "wrapperStyle.padding.right": {
          "slotId": "tokens.spacing.pageInline",
          "mode": "theme",
          "tokenPath": "tokens.spacing.pageInline",
          "fieldKind": "style"
        },
        "wrapperStyle.padding.bottom": {
          "slotId": "tokens.spacing.section",
          "mode": "theme",
          "tokenPath": "tokens.spacing.section",
          "fieldKind": "style"
        },
        "wrapperStyle.padding.left": {
          "slotId": "tokens.spacing.pageInline",
          "mode": "theme",
          "tokenPath": "tokens.spacing.pageInline",
          "fieldKind": "style"
        }
      }
    },
    "__demo_grid_cell_1__": {
      "id": "__demo_grid_cell_1__",
      "type": "text",
      "parentId": "__sample_grid__",
      "children": [],
      "wrapperStyle": {
        "placement": {
          "horizontal": "start",
          "vertical": "start"
        },
        "contentAlign": {
          "horizontal": "left",
          "vertical": "top"
        },
        "widthMode": "fill",
        "heightMode": "hug",
        "border": {
          "mode": "unified",
          "width": "0",
          "style": "solid",
          "color": "rgba(0,0,0,0)"
        },
        "borderRadius": {
          "mode": "unified",
          "radius": "0"
        }
      },
      "props": {
        "textBody": {
          "version": 1,
          "paragraphs": [
            {
              "runs": [
                {
                  "text": "栅格单元 1"
                }
              ]
            }
          ]
        },
        "fontSize": {
          "$themeRef": "tokens.typography.body"
        },
        "color": {
          "$themeRef": "colors.primary"
        },
        "fontFamily": {
          "$themeRef": "fonts.body"
        },
        "bold": false,
        "italic": false,
        "decoration": "none"
      },
      "bindings": {
        "props.fontSize": {
          "slotId": "tokens.typography.body",
          "mode": "theme",
          "tokenPath": "tokens.typography.body",
          "fieldKind": "style"
        },
        "props.color": {
          "slotId": "colors.primary",
          "mode": "theme",
          "tokenPath": "colors.primary",
          "fieldKind": "style"
        },
        "props.fontFamily": {
          "slotId": "fonts.body",
          "mode": "theme",
          "tokenPath": "fonts.body",
          "fieldKind": "style"
        }
      }
    },
