      "wrapperStyle": {
        "placement": {
          "horizontal": "center"
        },
        "widthMode": "fill",
        "heightMode": "hug"
      },
      "props": {
        "backgroundColor": "#FFFFFF",
        "width": "600px",
        "padding": {
          "mode": "unified",
          "unified": "0"
        },
        "border": {
          "mode": "unified",
          "width": "0",
          "style": "solid",
          "color": "rgba(0,0,0,0)"
        },
        "gapMode": "fixed",
        "gap": "0"
      },
      "bindings": {}
    },
    "__sample_grid__": {
      "id": "__sample_grid__",
      "type": "grid",
