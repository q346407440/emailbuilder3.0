{
  "schemaVersion": "4.0.0",
  "masterId": "action.button",
  "name": "按钮",
  "version": "1.0.0",
  "description": "行动按钮，文案与链接为内容字段，buttonStyle 控制按钮胶囊本体样式。",
  "runtimeType": "button",
  "blockType": "action.button",
  "sampleBlockId": "__sample_button__",
  "catalogRootBlockId": "__catalog_root__",
  "root": {
    "id": "__catalog_root__",
    "type": "emailRoot",
    "blockMeta": {
      "blockType": "layout.container",
      "name": "预览根"
    },
    "props": {
      "backgroundColor": "#FFFFFF",
      "width": "600px",
      "padding": {
        "top": "0",
        "right": "0",
        "bottom": "0",
        "left": "0"
      },
      "border": {
        "style": "solid",
        "color": "rgba(0,0,0,0)",
        "top": "0",
        "right": "0",
        "bottom": "0",
        "left": "0"
      },
      "gapMode": "fixed",
      "gap": "0"
    },
    "wrapperStyle": {
      "widthMode": "fill",
      "heightMode": "hug"
    },
    "children": [
      {
        "id": "__sample_button__",
        "type": "button",
        "blockMeta": {
          "blockType": "action.button",
          "name": "按钮"
        },
        "props": {
          "text": "按钮",
          "link": "https://example.com",
          "buttonStyle": {
            "widthMode": "hug",
            "backgroundColor": {
              "$themeRef": "colors.surface"
            },
            "textColor": {
              "$themeRef": "colors.primary"
            },
            "fontSize": {
              "$themeRef": "tokens.typography.body"
            },
            "border": {
              "style": "solid",
              "color": {
                "$themeRef": "colors.primary"
              },
              "top": "1px",
              "right": "1px",
              "bottom": "1px",
              "left": "1px"
            },
            "borderRadius": {
              "topLeft": {
                "$themeRef": "tokens.radius.cta"
              },
              "topRight": {
                "$themeRef": "tokens.radius.cta"
              },
              "bottomRight": {
                "$themeRef": "tokens.radius.cta"
              },
              "bottomLeft": {
                "$themeRef": "tokens.radius.cta"
              }
            },
            "bold": false,
            "italic": false
          }
        },
        "wrapperStyle": {
          "contentAlign": {
            "horizontal": "left",
            "vertical": "top"
          },
          "widthMode": "hug",
          "heightMode": "hug",
          "border": {
            "style": "solid",
            "color": "rgba(0,0,0,0)",
            "top": "0",
            "right": "0",
            "bottom": "0",
            "left": "0"
          },
          "borderRadius": {
            "topLeft": "0",
            "topRight": "0",
            "bottomRight": "0",
            "bottomLeft": "0"
          }
        },
        "bindings": {
          "props.buttonStyle.backgroundColor": {
            "slotId": "colors.surface",
            "mode": "theme",
            "tokenPath": "colors.surface",
            "fieldKind": "style"
          },
          "props.buttonStyle.textColor": {
            "slotId": "colors.primary",
            "mode": "theme",
            "tokenPath": "colors.primary",
            "fieldKind": "style"
          },
          "props.buttonStyle.fontSize": {
            "slotId": "tokens.typography.body",
            "mode": "theme",
            "tokenPath": "tokens.typography.body",
            "fieldKind": "style"
          },
          "props.buttonStyle.border.color": {
            "slotId": "colors.primary",
            "mode": "theme",
            "tokenPath": "colors.primary",
            "fieldKind": "style"
          },
          "props.buttonStyle.borderRadius.topLeft": {
            "slotId": "tokens.radius.cta",
            "mode": "theme",
            "tokenPath": "tokens.radius.cta",
            "fieldKind": "style"
          },
          "props.buttonStyle.borderRadius.topRight": {
            "slotId": "tokens.radius.cta",
            "mode": "theme",
            "tokenPath": "tokens.radius.cta",
            "fieldKind": "style"
          },
          "props.buttonStyle.borderRadius.bottomRight": {
            "slotId": "tokens.radius.cta",
            "mode": "theme",
            "tokenPath": "tokens.radius.cta",
            "fieldKind": "style"
          },
          "props.buttonStyle.borderRadius.bottomLeft": {
            "slotId": "tokens.radius.cta",
            "mode": "theme",
            "tokenPath": "tokens.radius.cta",
            "fieldKind": "style"
          }
        }
      }
    ]
  }
}
