{
  "masterId": "action.button",
  "name": "按钮",
  "version": "1.0.0",
  "description": "行动按钮，文案与链接为内容字段，buttonStyle 控制按钮胶囊本体样式。",
  "runtimeType": "button",
  "blockType": "action.button",
  "sampleBlockId": "__sample_button__",
  "catalogRootBlockId": "__catalog_root__",
  "blocks": {
    "__catalog_root__": {
      "id": "__catalog_root__",
      "type": "emailRoot",
      "parentId": null,
      "children": [
        "__sample_button__"
      ],
      "wrapperStyle": {
        "placement": {
          "horizontal": "center"
        },
        "widthMode": "fill",
        "heightMode": "hug"
      },
      "props": {
        "backgroundColor": "#FFFFFF",
        "width": "600px",
        "padding": {
          "mode": "unified",
          "unified": "0"
        },
        "border": {
          "mode": "unified",
          "width": "0",
          "style": "solid",
          "color": "rgba(0,0,0,0)"
        },
        "gapMode": "fixed",
        "gap": "0"
      },
      "bindings": {}
    },
    "__sample_button__": {
      "id": "__sample_button__",
      "type": "button",
      "parentId": "__catalog_root__",
      "children": [],
      "wrapperStyle": {
        "placement": {
          "horizontal": "center",
          "vertical": "start"
        },
        "contentAlign": {
          "horizontal": "left",
          "vertical": "top"
        },
        "widthMode": "hug",
        "heightMode": "hug",
        "border": {
          "mode": "unified",
          "width": "0",
          "style": "solid",
          "color": "rgba(0,0,0,0)"
        },
        "borderRadius": {
          "mode": "unified",
          "radius": "0"
        }
      },
      "props": {
        "text": "按钮",
        "link": "https://example.com",
        "buttonStyle": {
          "widthMode": "hug",
          "backgroundColor": {
            "$themeRef": "colors.surface"
          },
          "textColor": {
            "$themeRef": "colors.primary"
          },
          "fontFamily": {
            "$themeRef": "fonts.body"
          },
          "fontSize": {
            "$themeRef": "tokens.typography.body"
          },
          "border": {
            "mode": "unified",
            "width": "1px",
            "style": "solid",
            "color": {
              "$themeRef": "colors.primary"
            }
          },
          "borderRadius": {
            "mode": "unified",
            "radius": {
              "$themeRef": "tokens.radius.cta"
            }
          },
          "bold": false,
          "italic": false
        }
      },
      "bindings": {
        "props.buttonStyle.backgroundColor": {
          "slotId": "colors.surface",
          "mode": "theme",
          "tokenPath": "colors.surface",
          "fieldKind": "style"
        },
        "props.buttonStyle.textColor": {
          "slotId": "colors.primary",
          "mode": "theme",
          "tokenPath": "colors.primary",
          "fieldKind": "style"
        },
        "props.buttonStyle.fontFamily": {
          "slotId": "fonts.body",
          "mode": "theme",
          "tokenPath": "fonts.body",
          "fieldKind": "style"
        },
        "props.buttonStyle.fontSize": {
          "slotId": "tokens.typography.body",
          "mode": "theme",
          "tokenPath": "tokens.typography.body",
          "fieldKind": "style"
        },
        "props.buttonStyle.border.color": {
          "slotId": "colors.primary",
          "mode": "theme",
          "tokenPath": "colors.primary",
          "fieldKind": "style"
        },
        "props.buttonStyle.borderRadius.radius": {
          "slotId": "tokens.radius.cta",
          "mode": "theme",
          "tokenPath": "tokens.radius.cta",
          "fieldKind": "style"
        }
      }
    }
  },
  "blockMeta": {
    "__catalog_root__": {
      "blockType": "layout.container",
      "name": "预览根"
    },
    "__sample_button__": {
      "blockType": "action.button",
      "name": "按钮"
    }
  },
  "configSchema": {
    "schemaVersion": "1.0.0",
    "scopes": [
      {
        "scopeId": "template",
        "kind": "template",
        "label": "整封邮件",
        "fields": [
          {
            "key": "templateWidth",
            "label": "邮件宽度",
            "control": "text",
            "target": {
              "kind": "templatePath",
              "path": "blocks.__catalog_root__.props.width"
            }
          }
        ]
      },
      {
        "scopeId": "block:__sample_button__",
        "kind": "block",
        "label": "按钮",
        "blockIds": [
          "__sample_button__"
        ],
        "fields": [
          {
            "key": "props_buttonStyle_backgroundColor_token",
            "label": "props.buttonStyle.backgroundColor 样式档位",
            "control": "tokenScale",
            "tokenFamily": "colors",
            "defaultScale": "surface",
            "allowCustom": true,
            "target": {
              "kind": "blockPath",
              "blockId": "__sample_button__",
              "path": "props.buttonStyle.backgroundColor"
            }
          },
          {
            "key": "props_buttonStyle_textColor_token",
            "label": "props.buttonStyle.textColor 样式档位",
            "control": "tokenScale",
            "tokenFamily": "colors",
            "defaultScale": "primary",
            "allowCustom": true,
            "target": {
              "kind": "blockPath",
              "blockId": "__sample_button__",
              "path": "props.buttonStyle.textColor"
            }
          },
          {
            "key": "props_buttonStyle_fontFamily_token",
            "label": "props.buttonStyle.fontFamily 样式档位",
            "control": "tokenScale",
            "tokenFamily": "fonts",
            "defaultScale": "body",
            "allowCustom": true,
            "target": {
              "kind": "blockPath",
              "blockId": "__sample_button__",
              "path": "props.buttonStyle.fontFamily"
            }
          },
          {
            "key": "props_buttonStyle_fontSize_token",
            "label": "props.buttonStyle.fontSize 样式档位",
            "control": "tokenScale",
            "tokenFamily": "typography",
            "defaultScale": "body",
            "allowCustom": true,
            "target": {
              "kind": "blockPath",
              "blockId": "__sample_button__",
              "path": "props.buttonStyle.fontSize"
            }
          },
          {
            "key": "props_buttonStyle_border_color_token",
            "label": "props.buttonStyle.border.color 样式档位",
            "control": "tokenScale",
            "tokenFamily": "colors",
            "defaultScale": "primary",
            "allowCustom": true,
            "target": {
              "kind": "blockPath",
              "blockId": "__sample_button__",
              "path": "props.buttonStyle.border.color"
            }
          },
          {
            "key": "props_buttonStyle_borderRadius_radius_token",
            "label": "props.buttonStyle.borderRadius.radius 样式档位",
            "control": "tokenScale",
            "tokenFamily": "radius",
            "defaultScale": "cta",
            "allowCustom": true,
            "target": {
              "kind": "blockPath",
              "blockId": "__sample_button__",
              "path": "props.buttonStyle.borderRadius.radius"
            }
          }
        ]
      }
    ]
  }
}
