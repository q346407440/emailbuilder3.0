{
  "schemaVersion": "4.0.0",
  "masterId": "indicator.progress",
  "name": "进度条",
  "version": "1.0.0",
  "description": "横向进度条；槽/进度色与数值在 props；条带宽度、高度与圆角在 props，外层容器样式在 wrapperStyle。",
  "runtimeType": "progress",
  "blockType": "indicator.progress",
  "sampleBlockId": "__sample_progress__",
  "catalogRootBlockId": "__catalog_root__",
  "root": {
    "id": "__catalog_root__",
    "type": "emailRoot",
    "blockMeta": {
      "blockType": "layout.container",
      "name": "预览根"
    },
    "props": {
      "backgroundColor": "#FFFFFF",
      "width": "600px",
      "padding": {
        "top": "0",
        "right": "0",
        "bottom": "0",
        "left": "0"
      },
      "border": {
        "style": "solid",
        "color": "rgba(0,0,0,0)",
        "top": "0",
        "right": "0",
        "bottom": "0",
        "left": "0"
      },
      "gapMode": "fixed",
      "gap": "0"
    },
    "wrapperStyle": {
      "widthMode": "fill",
      "heightMode": "hug"
    },
    "children": [
      {
        "id": "__sample_progress__",
        "type": "progress",
        "blockMeta": {
          "blockType": "indicator.progress",
          "name": "进度条"
        },
        "props": {
          "trackColor": {
            "$themeRef": "colors.surface"
          },
          "fillColor": {
            "$themeRef": "colors.primary"
          },
          "value": 20,
          "max": 100,
          "barWidthMode": "fill",
          "barHeight": "10px",
          "barBorderRadius": {
            "topLeft": {
              "$themeRef": "tokens.radius.cta"
            },
            "topRight": {
              "$themeRef": "tokens.radius.cta"
            },
            "bottomRight": {
              "$themeRef": "tokens.radius.cta"
            },
            "bottomLeft": {
              "$themeRef": "tokens.radius.cta"
            }
          }
        },
        "wrapperStyle": {
          "contentAlign": {
            "horizontal": "left",
            "vertical": "top"
          },
          "widthMode": "fill",
          "heightMode": "hug",
          "border": {
            "style": "solid",
            "color": "rgba(0,0,0,0)",
            "top": "0",
            "right": "0",
            "bottom": "0",
            "left": "0"
          },
          "borderRadius": {
            "topLeft": "0",
            "topRight": "0",
            "bottomRight": "0",
            "bottomLeft": "0"
          }
        },
        "bindings": {
          "props.trackColor": {
            "slotId": "colors.surface",
            "mode": "theme",
            "tokenPath": "colors.surface",
            "fieldKind": "style"
          },
          "props.fillColor": {
            "slotId": "colors.primary",
            "mode": "theme",
            "tokenPath": "colors.primary",
            "fieldKind": "style"
          },
          "props.barBorderRadius.topLeft": {
            "slotId": "tokens.radius.cta",
            "mode": "theme",
            "tokenPath": "tokens.radius.cta",
            "fieldKind": "style"
          },
          "props.barBorderRadius.topRight": {
            "slotId": "tokens.radius.cta",
            "mode": "theme",
            "tokenPath": "tokens.radius.cta",
            "fieldKind": "style"
          },
          "props.barBorderRadius.bottomRight": {
            "slotId": "tokens.radius.cta",
            "mode": "theme",
            "tokenPath": "tokens.radius.cta",
            "fieldKind": "style"
          },
          "props.barBorderRadius.bottomLeft": {
            "slotId": "tokens.radius.cta",
            "mode": "theme",
            "tokenPath": "tokens.radius.cta",
            "fieldKind": "style"
          }
        }
      }
    ]
  }
}
