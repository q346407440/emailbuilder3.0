{
  "schemaVersion": "4.0.0",
  "masterId": "separator.divider",
  "name": "分割线",
  "version": "1.0.0",
  "description": "水平分割线，颜色、粗细与线条本体宽度为样式字段。",
  "runtimeType": "divider",
  "blockType": "separator.divider",
  "sampleBlockId": "__sample_divider__",
  "catalogRootBlockId": "__catalog_root__",
  "root": {
    "id": "__catalog_root__",
    "type": "emailRoot",
    "blockMeta": {
      "blockType": "layout.container",
      "name": "预览根"
    },
    "props": {
      "backgroundColor": "#FFFFFF",
      "width": "600px",
      "padding": {
        "mode": "unified",
        "unified": "0"
      },
      "border": {
        "mode": "unified",
        "width": "0",
        "style": "solid",
        "color": "rgba(0,0,0,0)"
      },
      "gapMode": "fixed",
      "gap": "0"
    },
    "wrapperStyle": {
      "widthMode": "fill",
      "heightMode": "hug"
    },
    "children": [
      {
        "id": "__sample_divider__",
        "type": "divider",
        "blockMeta": {
          "blockType": "separator.divider",
          "name": "分割线"
        },
        "props": {
          "color": {
            "$themeRef": "colors.secondary"
          },
          "lineWidthMode": "fill",
          "height": "2px"
        },
        "wrapperStyle": {
          "widthMode": "fill",
          "heightMode": "hug",
          "contentAlign": {
            "horizontal": "left",
            "vertical": "top"
          },
          "padding": {
            "mode": "separate",
            "top": {
              "$themeRef": "tokens.spacing.section"
            },
            "right": {
              "$themeRef": "tokens.spacing.pageInline"
            },
            "bottom": {
              "$themeRef": "tokens.spacing.section"
            },
            "left": {
              "$themeRef": "tokens.spacing.pageInline"
            }
          }
        },
        "bindings": {
          "props.color": {
            "slotId": "colors.secondary",
            "mode": "theme",
            "tokenPath": "colors.secondary",
            "fieldKind": "style"
          },
          "wrapperStyle.padding.top": {
            "slotId": "tokens.spacing.section",
            "mode": "theme",
            "tokenPath": "tokens.spacing.section",
            "fieldKind": "style"
          },
          "wrapperStyle.padding.right": {
            "slotId": "tokens.spacing.pageInline",
            "mode": "theme",
            "tokenPath": "tokens.spacing.pageInline",
            "fieldKind": "style"
          },
          "wrapperStyle.padding.bottom": {
            "slotId": "tokens.spacing.section",
            "mode": "theme",
            "tokenPath": "tokens.spacing.section",
            "fieldKind": "style"
          },
          "wrapperStyle.padding.left": {
            "slotId": "tokens.spacing.pageInline",
            "mode": "theme",
            "tokenPath": "tokens.spacing.pageInline",
            "fieldKind": "style"
          }
        }
      }
    ]
  }
}
