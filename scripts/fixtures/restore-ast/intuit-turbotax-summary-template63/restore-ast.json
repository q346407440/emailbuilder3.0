                    "children": [
                      {
                        "t": "icon",
                        "query": "clock",
                        "pack": "tabler",
                        "size": "md",
                        "tone": "accent",
                        "required": true
                      },
                      {
                        "t": "text",
                        "content": "Last year, you started your taxes 4/11/2024",
                        "role": "body",
                        "bold": true
                      }
                    ]
                  },
                  {
                    "t": "stack",
                    "title": "扣除优化卡",
                    "align": "start",
                    "gap": "gap",
                    "box": {
                      "pad": "gap",
                      "tone": {
                        "hex": "#262D33"
                      },
                      "radius": "panel"
                    },
                    "children": [
                      {
                        "t": "icon",
                        "query": "cash",
                        "pack": "tabler",
                        "size": "md",
