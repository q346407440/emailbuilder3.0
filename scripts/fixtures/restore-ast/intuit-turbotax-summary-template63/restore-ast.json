                    "children": [
                      {
                        "t": "icon",
                        "query": "pig-money",
                        "pack": "tabler",
                        "size": "md",
                        "required": true
                      },
                      {
                        "t": "text",
                        "content": "You got a Federal Refund. View in your account >",
                        "role": "body",
                        "bold": true
                      }
                    ]
                  },
                  {
                    "t": "stack",
                    "title": "申报状态卡",
                    "align": "start",
                    "gap": "gap",
                    "box": {
                      "pad": "section",
                      "tone": {
                        "hex": "#F4D4DB"
                      },
                      "radius": "panel"
                    },
                    "children": [
                      {
                        "t": "icon",
                        "query": "rings",
                        "pack": "tabler",
                        "size": "md",
                        "tone": "accent",
                        "required": true
                      },
                      {
                        "t": "text",
                        "content": "Your filing status Married filing jointly",
                        "role": "body",
                        "bold": true
                      }
                    ]
                  }
                ]
              }
            ]
          },
          {
            "t": "button",
            "label": "Make updates",
            "href": "#",
            "tone": "surface"
