{
  "theme": {
    "colors": {
      "primary": "#0077C8",
      "accent": "#C93B59",
      "secondary": "#6B7280",
      "surface": "#FFFFFF"
    },
    "spacing": {
      "section": "24px",
      "gap": "12px",
      "pageInline": "20px"
    },
    "typography": {
      "display": "32px",
      "h1": "22px",
      "body": "15px",
      "caption": "11px"
    },
    "radius": {
      "panel": "12px",
      "cta": "999px"
    }
  },
  "tree": {
    "t": "email",
    "children": [
      {
        "t": "stack",
        "title": "顶部品牌与登录",
        "align": "start",
        "gap": "gap",
        "box": {
          "pad": "section",
          "tone": "surface"
        },
        "children": [
          {
            "t": "row",
            "title": "品牌与登录行",
            "align": "between",
            "crossAlign": "center",
            "gap": "gap",
            "children": [
              {
                "t": "stack",
                "title": "税务品牌区",
                "align": "start",
                "gap": "gap",
                "children": [
                  {
                    "t": "icon",
                    "query": "file-invoice",
                    "pack": "tabler",
                    "required": true,
                    "size": "lg",
                    "tone": "primary"
                  }
                ]
              },
              {
                "t": "stack",
                "title": "快捷登录区",
                "align": "end",
                "gap": "gap",
                "children": [
                  {
                    "t": "text",
                    "content": "Kickstart your taxes with one step",
                    "role": "caption",
                    "tone": "secondary"
                  },
                  {
                    "t": "button",
                    "label": "Sign in",
                    "href": "#"
                  }
                ]
              }
            ]
          }
        ]
      },
      {
        "t": "stack",
        "title": "W-2 通知条",
        "align": "start",
        "gap": "gap",
        "box": {
          "pad": "gap",
          "tone": {
            "hex": "#262D33"
          }
        },
        "children": [
          {
            "t": "row",
            "title": "W-2 可用提示",
            "align": "between",
            "crossAlign": "center",
            "gap": "gap",
            "children": [
              {
                "t": "row",
                "title": "W-2 文案组",
                "align": "start",
                "crossAlign": "center",
                "gap": "gap",
                "children": [
                  {
                    "t": "icon",
                    "query": "file-invoice",
                    "pack": "tabler",
                    "size": "md",
                    "tone": "surface",
                    "required": true
                  },
                  {
                    "t": "text",
                    "content": "Your W-2 from RGE LLC is available",
                    "role": "body",
                    "tone": "surface",
                    "bold": true
                  }
                ]
              },
              {
                "t": "icon",
                "query": "chevron-right",
                "pack": "tabler",
                "size": "sm",
                "tone": "surface",
                "required": true
              }
            ]
          }
        ]
      },
      {
        "t": "stack",
        "title": "税季欢迎英雄区",
        "align": "center",
        "gap": "section",
        "box": {
          "pad": "section",
          "tone": {
            "hex": "#F0F0ED"
          }
        },
        "children": [
          {
            "t": "text",
            "content": "Welcome to Tax Year",
            "role": "caption",
            "tone": "surface",
            "bold": true
          },
          {
            "t": "image",
            "query": "2024 tax year celebration typography graphic pink red illustration sparkles",
            "height": {
              "px": 200
            },
            "required": true
          },
          {
            "t": "text",
            "content": "Get a head start: Review your info now",
            "role": "display",
            "bold": true
          },
          {
            "t": "text",
            "content": "Smiles Davis, as a returning customer, you're already a step ahead. Just confirm or update your details.",
            "role": "body"
          },
          {
            "t": "button",
            "label": "Verify your info",
            "href": "#"
          }
        ]
      },
      {
        "t": "stack",
        "title": "税务摘要宫格",
        "align": "center",
        "gap": "section",
        "box": {
          "pad": "section",
          "tone": {
            "hex": "#F0F0ED"
          }
        },
        "children": [
          {
            "t": "stack",
            "title": "2023 回顾宽卡",
            "align": "start",
            "gap": "gap",
            "box": {
              "pad": "section",
              "tone": {
                "hex": "#E8E8E4"
              },
              "radius": "panel"
