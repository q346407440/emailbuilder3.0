                  {
                    "t": "stack",
                    "title": "Premium 使用卡",
                    "align": "start",
                    "gap": "gap",
                    "box": {
                      "pad": "gap",
                      "tone": {
                        "hex": "#E8E8E4"
                      },
                      "radius": "panel"
                    },
                    "children": [
                      {
                        "t": "icon",
                        "query": "flag",
                        "pack": "tabler",
                        "size": "md",
                        "required": true
                      },
                      {
                        "t": "text",
                        "content": "You used TurboTax Premium",
                        "role": "body",
                        "bold": true
                      }
                    ]
                  }
                ]
              },
              {
                "t": "stack",
                "title": "右列摘要卡",
                "align": "start",
                "gap": "gap",
                "children": [
                  {
                    "t": "stack",
                    "title": "联邦退税卡",
                    "align": "start",
                    "gap": "gap",
                    "box": {
                      "pad": "section",
                      "tone": {
                        "hex": "#E8E8E4"
                      },
                      "radius": "panel"
