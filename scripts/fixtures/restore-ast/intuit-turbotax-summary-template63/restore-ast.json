                    "gap": "gap",
                    "children": [
                      {
                        "t": "text",
                        "content": "Smiles Davis, your 2023 tax year in review",
                        "role": "h1",
                        "bold": true
                      }
                    ]
                  },
                  {
                    "t": "image",
                    "query": "line art illustration person reviewing tax documents minimalist",
                    "height": {
                      "px": 120
                    },
                    "aspect": {
                      "w": 4,
                      "h": 3
                    },
                    "required": true
                  }
                ]
              }
            ]
          },
          {
            "t": "grid",
            "title": "摘要双列宫格",
            "columns": 2,
            "gap": "gap",
            "children": [
              {
                "t": "stack",
                "title": "左列摘要卡",
                "align": "start",
                "gap": "gap",
                "children": [
                  {
                    "t": "stack",
                    "title": "报税开始时间卡",
                    "align": "start",
                    "gap": "gap",
                    "box": {
                      "pad": "gap",
