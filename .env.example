# 复制为 .env 并填入测试邮箱 SMTP（勿提交 .env 到 Git）
# 使用 ./start.sh 或 export 后启动 API 时会自动加载

# 本地 API 端口（可选，默认 8787）
# EMAIL_API_PORT=8787

# SMTP 测试发信（Meta 面板「发送测试邮件」）
EMAIL_SMTP_HOST=smtp.example.com
EMAIL_SMTP_PORT=465
EMAIL_SMTP_SECURE=true
EMAIL_SMTP_USER=your-test@example.com
EMAIL_SMTP_PASS=your-app-password-or-smtp-password
EMAIL_SMTP_FROM=your-test@example.com
EMAIL_SMTP_FROM_NAME="Easy-Email 测试"

# --- 以图创建版式 / 还原管线（从 handoff 服务器 .env 复制，勿提交 .env）---
# 豆包 · 火山方舟 Ark（handoff: modelConfig.ts + doubaoAdapter.ts）
# DOUBAO_API_KEY=
# DOUBAO_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
# DOUBAO_REASONING_EFFORT=medium
# LLM_PIPELINE_VENDOR=doubao
# LLM_PIPELINE_MODEL=ep-xxxxxxxx
#
# Pexels 真实配图（handoff: pexelsClient.ts；本仓库 src/lib/pexelsClient.ts）
# PEXELS_API_KEY=
